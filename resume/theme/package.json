{
  "name": "jsonresume-theme-escemi",
  "version": "2.0.0",
  "description": "A professional JSON Resume theme optimized for senior technical profiles following CV Coach best practices - React edition",
  "type": "module",
  "main": "./dist/jsonresume-theme-escemi.cjs",
  "module": "./dist/jsonresume-theme-escemi.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/jsonresume-theme-escemi.js",
      "require": "./dist/jsonresume-theme-escemi.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "tailwind.config.cjs",
    "postcss.config.cjs",
    "tsconfig.build.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage.enabled --coverage.reporter=lcov --coverage.reporter=text",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "author": "ESCEMI",
  "repository": {
    "type": "git",
    "url": "https://github.com/escemi-tech/.github"
  },
  "keywords": [
    "jsonresume",
    "theme",
    "cv",
    "resume",
    "technical",
    "senior",
    "cto",
    "lead-developer",
    "react",
    "cv-coach"
  ],
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "dependencies": {
    "@fontsource/source-sans-pro": "^5.1.0",
    "pagedjs": "^0.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "@tailwindcss/typography": "^0.5.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "react-to-print": "^3.3.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.0.13"
  }
}
